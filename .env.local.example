# Notion Integration
# Create a Notion integration at https://www.notion.so/my-integrations
# Then share your leads database with the integration
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

